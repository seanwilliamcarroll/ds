#!/usr/bin/env bash

echo "==> pre-push: clean build with check preset and running tests"

rm -rf build-check
cmake --preset check 2>&1
if [ $? -ne 0 ]; then
    echo "==> pre-push: CMAKE CONFIGURE FAILED — push blocked"
    exit 1
fi

cmake --build --preset check 2>&1
if [ $? -ne 0 ]; then
    echo "==> pre-push: BUILD FAILED (warnings treated as errors) — push blocked"
    exit 1
fi

ctest --preset check 2>&1
if [ $? -ne 0 ]; then
    echo "==> pre-push: TESTS FAILED — push blocked"
    exit 1
fi

echo "==> pre-push: all checks passed"
