#!/usr/bin/env bash

echo "==> pre-push: clean build with -Werror and running tests"

rm -rf build-check
cmake -B build-check -DCMAKE_CXX_FLAGS="-Werror" . 2>&1
if [ $? -ne 0 ]; then
    echo "==> pre-push: CMAKE CONFIGURE FAILED — push blocked"
    exit 1
fi

cmake --build build-check 2>&1
if [ $? -ne 0 ]; then
    echo "==> pre-push: BUILD FAILED (warnings treated as errors) — push blocked"
    exit 1
fi

ctest --test-dir build-check --output-on-failure 2>&1
if [ $? -ne 0 ]; then
    echo "==> pre-push: TESTS FAILED — push blocked"
    exit 1
fi

echo "==> pre-push: all checks passed"
