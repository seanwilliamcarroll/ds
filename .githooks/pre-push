#!/usr/bin/env bash

# Bail early if there are no commits to push.
# If there's no upstream tracking branch, this is a first push — always run checks.
if git rev-parse --verify @{u} &>/dev/null; then
    if [ -z "$(git log @{u}..HEAD)" ]; then
        echo "==> pre-push: nothing to push, skipping checks"
        exit 0
    fi
fi

echo "==> pre-push: clean build with check preset and running tests"

# Stash uncommitted changes so the build tests exactly what's being pushed
stashed=false
if ! git diff --quiet || ! git diff --cached --quiet; then
    git stash push -m "pre-push hook" --include-untracked
    stashed=true
fi

cleanup() {
    if [ "$stashed" = true ]; then
        git stash pop --quiet
    fi
}

rm -rf build-check
cmake --preset check 2>&1
if [ $? -ne 0 ]; then
    echo "==> pre-push: CMAKE CONFIGURE FAILED — push blocked"
    cleanup
    exit 1
fi

cmake --build --preset check 2>&1
if [ $? -ne 0 ]; then
    echo "==> pre-push: BUILD FAILED (warnings treated as errors) — push blocked"
    cleanup
    exit 1
fi

ctest --preset check 2>&1
if [ $? -ne 0 ]; then
    echo "==> pre-push: TESTS FAILED — push blocked"
    cleanup
    exit 1
fi

echo "==> pre-push: running clang-tidy (parallel)"
SOURCE_FILES=$(find . -path './build*' -prune -o \( -name '*.hpp' -o -name '*.cpp' \) -print \
    | grep -v '_test\.cpp$' | grep -v '_bench\.cpp$')

if [ -n "$SOURCE_FILES" ]; then
    echo "$SOURCE_FILES" | xargs -P 0 -n 1 clang-tidy -p build-check --warnings-as-errors='*' 2>&1
    if [ $? -ne 0 ]; then
        echo "==> pre-push: CLANG-TIDY WARNINGS — push blocked"
        cleanup
        exit 1
    fi
fi

cleanup
echo "==> pre-push: all checks passed"
